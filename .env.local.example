# Google Apps Script Web App URL for waitlist submissions
# 1. Create a new Google Sheet
# 2. Extensions > Apps Script
# 3. Paste the script from comments in app/api/waitlist/route.ts
# 4. Deploy > New deployment > Web app > Execute as Me, Anyone can access
# 5. Copy the deployment URL here
GOOGLE_SHEETS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
